# Biến môi trường cho API Gateway

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL - Database của Gateway (quản lý tài khoản users)
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password
DB_NAME=users_db

# JWT - Khóa bí mật để ký và giải mã token
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# gRPC - Địa chỉ các Microservice nội bộ
TRIP_SERVICE_URL=localhost:50051
SEAT_SERVICE_URL=localhost:50052
BOOKING_SERVICE_URL=localhost:50053
PAYMENT_SERVICE_URL=localhost:50054
ADMIN_SERVICE_URL=localhost:50055

# Redis - Dùng để lắng nghe sự kiện ghế real-time từ seat-service (Giai đoạn 4)
REDIS_HOST=localhost
REDIS_PORT=6379

# Channel Redis Pub/Sub — phải khớp với seat-service
SEAT_EVENTS_CHANNEL=seat_status_updates
