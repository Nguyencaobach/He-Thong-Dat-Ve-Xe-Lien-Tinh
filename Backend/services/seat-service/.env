# Biến môi trường cho seat-service

# gRPC Server Port
GRPC_PORT=50052
GRPC_HOST=0.0.0.0

# Redis - Kho lưu trữ chính (không dùng Postgres)
# seat-service dùng Redis làm "database" chính nhờ tốc độ gần 1ms
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis Pub/Sub Channel - Kênh phát sự kiện ghế real-time
SEAT_EVENTS_CHANNEL=seat_status_updates

# TTL giữ ghế (giây) — 300 = 5 phút
SEAT_HOLD_TTL=300

# RabbitMQ - Dùng để publish sự kiện ghế bị lock/hết hạn (cho Giai đoạn 5+)
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
