# Biến môi trường cho admin-service

# gRPC Server
GRPC_PORT=50055
GRPC_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL - admin_db
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password
DB_NAME=admin_db

# gRPC — Địa chỉ các service cần gọi
BOOKING_SERVICE_URL=localhost:50053
SEAT_SERVICE_URL=localhost:50052

# RabbitMQ — Publish admin events (check-in, block_seat) lên analytics
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
ADMIN_EVENTS_EXCHANGE=admin.events
