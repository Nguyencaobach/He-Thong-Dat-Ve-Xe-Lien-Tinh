# Server
GRPC_PORT=50051
GRPC_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL - trip_db
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password
DB_NAME=trip_db

# Redis - Cache tìm kiếm chuyến xe
REDIS_HOST=localhost
REDIS_PORT=6379
SEARCH_CACHE_TTL=300

# Kafka - Outbox Pattern (đẩy search-events)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=trip-service
KAFKA_TOPIC_SEARCH_EVENTS=search-events

# Outbox Worker
TRIP_OUTBOX_POLL_INTERVAL_MS=2000
TRIP_OUTBOX_BATCH_SIZE=20
TRIP_OUTBOX_MAX_ATTEMPTS=5
