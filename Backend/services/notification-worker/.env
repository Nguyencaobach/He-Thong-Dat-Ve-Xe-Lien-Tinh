# Biến môi trường cho notification-worker

NODE_ENV=development

# RabbitMQ - Nhận ticket.issued
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
TICKET_EVENTS_EXCHANGE=ticket.events
TICKET_ISSUED_QUEUE=notification.ticket_issued

# Email giả lập (nodemailer + Ethereal hoặc chỉ ghi log)
# Chế độ: "log" (chỉ ghi log) hoặc "ethereal" (dùng Ethereal test mail)
EMAIL_MODE=log

# Chỉ cần thiết khi EMAIL_MODE=ethereal
# ETHEREAL_USER=your_ethereal_user
# ETHEREAL_PASS=your_ethereal_pass

# Email người gửi hiển thị
EMAIL_FROM="Hệ thống đặt vé xe <noreply@bussystem.local>"
