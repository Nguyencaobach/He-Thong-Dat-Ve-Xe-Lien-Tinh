# Biến môi trường cho ticket-worker

NODE_ENV=development

# RabbitMQ - Kết nối để nhận booking.paid và publish ticket.issued
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# Exchange nhận booking.paid (phải khớp với booking-service)
BOOKING_EVENTS_EXCHANGE=booking.events
BOOKING_PAID_QUEUE=ticket.booking_paid

# Exchange publish ticket.issued (notification-worker sẽ subscribe)
TICKET_EVENTS_EXCHANGE=ticket.events

# Thư mục lưu file vé HTML
TICKETS_OUTPUT_DIR=./generated-tickets
