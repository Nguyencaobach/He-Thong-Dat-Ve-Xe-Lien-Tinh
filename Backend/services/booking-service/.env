# Biến môi trường cho booking-service

# gRPC Server
GRPC_PORT=50053
GRPC_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL - booking_db
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password
DB_NAME=booking_db

# gRPC — địa chỉ các service nội bộ (cần gọi seat-service và payment-service)
SEAT_SERVICE_URL=localhost:50052
PAYMENT_SERVICE_URL=localhost:50054

# RabbitMQ - Nhận sự kiện từ payment-service; publish booking.paid
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RABBITMQ_EXCHANGE=payment.events
BOOKING_PAID_EXCHANGE=booking.events

# Kafka - Đẩy thống kê booking.paid lên analytics
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=booking-service
KAFKA_TOPIC_BOOKING_EVENTS=booking-events

# TTL đơn hàng PENDING (giây) — phải bằng SEAT_HOLD_TTL của seat-service
BOOKING_PENDING_TTL=300

# Outbox Worker
BOOKING_OUTBOX_POLL_INTERVAL_MS=2000
BOOKING_OUTBOX_BATCH_SIZE=20
BOOKING_OUTBOX_MAX_ATTEMPTS=5
