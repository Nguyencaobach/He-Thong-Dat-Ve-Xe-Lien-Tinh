# Biến môi trường cho payment-service

# gRPC Server
GRPC_PORT=50054
GRPC_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL - payment_db (lưu lịch sử transactions)
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password
DB_NAME=payment_db

# RabbitMQ - Publish kết quả thanh toán
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
PAYMENT_EVENTS_EXCHANGE=payment.events

# Kafka - Đẩy thống kê thanh toán lên analytics
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-service
KAFKA_TOPIC_PAYMENT_EVENTS=payment-events

# Tỷ lệ thành công giả lập (0.0 - 1.0), 1.0 = luôn thành công
PAYMENT_SUCCESS_RATE=0.9
